<div class="new-main">
  <div class="question-new">
    <div class="question-header"></div>
    <div class="question-box">
      <div class="question-form">
        <%= form_with model: @question, local: true do |form| %>
          <div class="form-title">
            <%= form.text_field :title, placeholder:"タイトル" %>
          </div>
          <div class="form-content">
            <%= form.text_area :content, placeholder:"質問内容" %>
          </div>
          <div class="form-name">
            <%= form.text_field :name, placeholder:"投稿者名" %>
          </div>
          <div class="form-submit">
            <%= form.submit 'Post' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
